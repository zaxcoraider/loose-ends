# ── Slack (required) ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-token
SLACK_SIGNING_SECRET=your-signing-secret

# ── DGrid (required — OpenAI-compatible AI gateway for LLM extraction) ──
DGRID_API_KEY=your-dgrid-key
DGRID_BASE_URL=https://api.dgrid.ai/v1
DGRID_MODEL=anthropic/claude-sonnet-4.6

# ── RTS / Real-Time Search (optional — core works without it) ────
# Powers `/looseends ask`. Must be a USER token (xoxp-), not the bot token: RTS
# bot-token calls need an `action_token` that only exists inside message events,
# so a slash command can't use one. Add the USER scope `search:read.public` under
# OAuth & Permissions → User Token Scopes, reinstall the app, and paste the
# "User OAuth Token" here. Leave as-is to run DB-only.
SLACK_USER_TOKEN=xoxp-your-user-token

# ── Ticketing (optional) ─────────────────────────────────────────
# Base URL of the tracker the MCP connector writes to, e.g.
#   TICKET_BASE_URL=https://your-team.atlassian.net/browse
# Leave empty and ticket refs render as plain text — the bundled connector stores tickets
# locally, and a link to a host that doesn't exist is worse than no link. Set both here
# and in the MCP server's env to make refs clickable.
TICKET_BASE_URL=

# ── Demo (optional) ──────────────────────────────────────────────
# Channel that scripts/seed_demo.py wipes+seeds. Auto-detect needs the `channels:read`
# scope, which this app doesn't carry — so set it here or pass --channel C…
DEMO_CHANNEL=

# ── Tuning (optional; defaults shown) ────────────────────────────
CONFIDENCE_THRESHOLD=0.6
STALE_HOURS=4
